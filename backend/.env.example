# Workspace root
WORKSPACE_ROOT=/app/data/workspaces

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3002
WS_PORT=3003
NODE_ENV=production

# CORS
CORS_ORIGIN=https://your-frontend-domain.com

# Coze cross-dimensional market
# Server-side token for calling Coze Chat API v3. Never expose this in frontend env.
COZE_API_BASE=https://api.coze.com
COZE_API_TOKEN=
# Optional JSON array. Each item: {"botId":"...","name":"...","description":"...","icon":"...","tags":["Coze"],"category":"效率","creator":"Coze","rating":4.8,"deployCount":12000,"sourceUrl":"https://www.coze.com/store/bot/..."}
COZE_MARKET_BOTS=[]
