NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WS_URL=ws://localhost:3003

# Optional: used by Next.js rewrites when the frontend server proxies /auth and /api.
# In production this can be an internal backend address, while NEXT_PUBLIC_API_URL
# remains the public browser-facing API URL.
BACKEND_INTERNAL_URL=http://localhost:3002
